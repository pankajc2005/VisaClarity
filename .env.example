# =========================================================
# VisaClarity — environment variables
# =========================================================
# Copy to `.env` (local) or set in your host's dashboard.
# This file documents the contract so you can recreate it
# on any other host (Vercel, Netlify, Cloudflare Workers, VPS, etc.).

# ---------- Required on every host ----------

# Supabase — public (safe to ship to the browser)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Supabase — server-side (never expose to the browser)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Optional / portability ----------

# Override the canonical site URL after moving to a custom domain.
# Defaults to https://visaclarity.me
VITE_SITE_URL=

# Google Analytics 4 measurement ID. Leave blank to disable.
# Defaults to the current production ID for backward compatibility.
VITE_GA_MEASUREMENT_ID=

# ---------- AI + web research (server only) ----------

# Set to any OpenAI-compatible /v1/chat/completions endpoint
# (OpenRouter, Together, Groq, OpenAI, Azure).
AI_GATEWAY_URL=
AI_GATEWAY_API_KEY=

# Tavily web research API key — required for personalized roadmap research.
# Free tier at https://tavily.com.
TAVILY_API_KEY=

# ---------- Configurable storage backend ----------
# Default: "supabase" (uses Supabase Storage with SUPABASE_SERVICE_ROLE_KEY above).
# Set to "s3" to use any S3-compatible service (AWS S3, Cloudflare R2,
# Backblaze B2, MinIO). When s3, also install:
#   bun add @aws-sdk/client-s3 @aws-sdk/s3-request-presigner
STORAGE_BACKEND=
S3_REGION=
S3_ENDPOINT=          # leave blank for AWS; set for R2/MinIO
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=


# ---------- Blog Agent Free LLM Providers ----------
# At least ONE of these must be set for the blog agent to function.
# All are completely free. The system will fall back automatically if one fails.

# 1. OpenRouter (Free Tier) - Gets access to DeepSeek, Qwen, etc.
# Get free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# 2. Groq (Free Tier) - Llama 3.1 70B, extremely fast
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=

# 3. Google AI Studio (Free Tier) - Gemini Flash
# Get free key at: https://aistudio.google.com/apikey
GOOGLE_AI_KEY=

# Cron webhook authentication key
BLOG_API_KEY=
